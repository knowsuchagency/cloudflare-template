{
  "name": "cloudflare-better-auth-experiment-lw48",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types",
    "auth:generate": "better-auth generate --config ./better-auth.config.ts --output ./src/db/schema.ts -y",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply better-auth-experiment --local",
    "db:migrate:remote": "wrangler d1 migrations apply better-auth-experiment --remote"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "latest",
    "better-sqlite3": "^12.9.0",
    "drizzle-kit": "^0.31.10",
    "wrangler": "^4.83.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "better-auth": "^1.6.5",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.14"
  }
}
