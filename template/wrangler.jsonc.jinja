{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "{{ worker_name }}",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "logpush": true,
  "observability": { "enabled": true },
  "preview_urls": true,
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "{{ d1_database_name }}",
      "database_id": "REPLACE_WITH_ID_FROM_wrangler_d1_create",
      "migrations_dir": "./drizzle"
    }
  ],
  "assets": {
    "directory": "./web/dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "vars": {
    "BETTER_AUTH_URL": "http://localhost:8787"{% if cloudflare_account_subdomain %},
    // Workers Builds preview URLs (`<version>-{{ worker_name }}.<sub>.workers.dev`)
    // are siblings of the prod URL under the same account subdomain. Seeding the
    // wildcard here means auth works on previews even before `mise run deploy`
    // patches BETTER_AUTH_URL to the deployed origin (which would let
    // deriveTrustedOrigins() infer the same wildcard automatically).
    "BETTER_AUTH_TRUSTED_ORIGINS": "https://*.{{ cloudflare_account_subdomain }}.workers.dev"{% endif %}
  },
  // Branch deploys (anything that isn't `main`) ship as versions of a separate
  // Worker `{{ worker_name }}-preview` with its own D1, so schema changes can
  // be exercised end-to-end without touching production data. Workers Builds
  // invokes `wrangler versions upload --env preview` for the preview trigger.
  // d1_databases / vars are non-inheritable — every binding the preview worker
  // uses must be redeclared here.
  "env": {
    "preview": {
      "name": "{{ worker_name }}-preview",
      // `routes` IS inheritable. The day someone adds a top-level
      // custom-domain route here, the next `wrangler deploy --env preview`
      // would silently inherit it and reassign the prod hostname to the
      // preview Worker — an outage. Pinning routes=[] makes the preview
      // Worker incapable of owning a custom domain regardless of what
      // top-level config grows.
      "routes": [],
      "vars": {
        "BETTER_AUTH_URL": "http://localhost:8787"{% if cloudflare_account_subdomain %},
        "BETTER_AUTH_TRUSTED_ORIGINS": "https://*.{{ cloudflare_account_subdomain }}.workers.dev"{% endif %}
      },
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "{{ d1_database_name }}-preview",
          "database_id": "REPLACE_WITH_ID_FROM_wrangler_d1_create_preview",
          "migrations_dir": "./drizzle"
        }
      ]
    }
  }
}
