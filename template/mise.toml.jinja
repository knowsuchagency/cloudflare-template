[tools]
bun = "1.3.3"
node = "22"

# Tasks — run `mise tasks` to list them.
#
# First-time setup for a new checkout:
#   mise install              # pin bun + node per [tools] (copier already ran this on render)
#   bunx wrangler login       # one-time CF auth (skip if you're going headless)
#   mise init                 # installs deps, seeds .dev.vars, applies local D1
#                             # migrations, provisions remote D1 + BETTER_AUTH_SECRET,
#                             # applies remote migrations
#   mise dev                  # SPA on http://localhost:5173 (HMR), Worker on :8787
#   mise deploy               # ship to *.workers.dev
#
# On a headless box (no browser for `wrangler login`), export
# CLOUDFLARE_API_TOKEN in your shell and add --headless to init:
#   mise init --headless
# Every subsequent CF-touching task (d1:create, secret:put, migrate:remote,
# deploy, teardown) also reads CLOUDFLARE_API_TOKEN from the environment, so
# just keep it exported.
#
# To also create a private GitHub repo in the same step, pass --github:
#   mise init --github               # or combine: --headless --github
# init calls d1:create + secret:put + migrate:remote automatically whenever
# wrangler is authenticated, so the patched wrangler.jsonc is part of the
# initial commit pushed to GitHub.
#
# After the first deploy, wire Workers Builds so push → deploy works and PRs
# get preview URLs auto-commented:
#   mise run builds:connect          # creates repo connection + main + preview triggers (idempotent)
# One-time prerequisite: the Cloudflare Workers & Pages GitHub App must be
# authorized on the repo's owner. builds:connect detects this and prints the
# install link if needed.

[tasks.init]
description = "Install deps, seed .dev.vars, apply local migrations, provision remote D1 + BETTER_AUTH_SECRET + remote migrations (when authenticated), optionally create a private GitHub repo"
usage = '''
flag "--headless" help="verify CLOUDFLARE_API_TOKEN via wrangler whoami before installing"
flag "--github"   help="git-init (if needed), commit, and create a private GitHub repo named {{ project_slug }} with upstream set"
'''
run = '''
if [ "${usage_headless:-false}" = "true" ]; then
  have_token=0
  [ -n "${CLOUDFLARE_API_TOKEN:-}" ] && have_token=1
  [ -n "${CLOUDFLARE_API_KEY:-}" ] && [ -n "${CLOUDFLARE_EMAIL:-}" ] && have_token=1
  if [ "$have_token" = "0" ]; then
    echo "✗ --headless needs one of:" >&2
    echo "    CLOUDFLARE_API_TOKEN           (scoped token, preferred)" >&2
    echo "    CLOUDFLARE_API_KEY + CLOUDFLARE_EMAIL  (global key fallback)" >&2
    echo "  Export them, or run under a secret manager, e.g." >&2
    echo "    fnox exec -- mise run init --headless" >&2
    exit 1
  fi
  bunx wrangler whoami >/dev/null 2>&1 || {
    echo "✗ wrangler whoami rejected the provided credentials" >&2
    exit 1
  }
  echo "✓ wrangler authenticated"
fi

if [ "${usage_github:-false}" = "true" ]; then
  command -v gh >/dev/null 2>&1 || { echo "✗ --github requires the gh CLI (https://cli.github.com)" >&2; exit 1; }
  gh auth status >/dev/null 2>&1 || { echo "✗ gh is not authenticated — run: gh auth login" >&2; exit 1; }
  if [ ! -d .git ]; then
    git init -b main >/dev/null
    echo "✓ git initialized"
  fi
fi

bun install
bun install --cwd web

if [ -f .dev.vars ]; then
  echo "• .dev.vars already exists — leaving it alone"
else
  {
    echo "BETTER_AUTH_URL=http://localhost:5173"
    printf 'BETTER_AUTH_SECRET=%s\n' "$(openssl rand -base64 32)"
  } > .dev.vars
  echo "✓ created .dev.vars"
fi

# Apply migrations to the local D1 so `mise dev` works out of the box (no auth required).
mise run migrate:local

# Remote bootstrap — only if wrangler is already authenticated (always true under
# --headless, and true in interactive mode once the user has run `bunx wrangler login`).
# Provisions D1, uploads BETTER_AUTH_SECRET, and applies the initial migration to the
# remote D1 so `mise deploy` immediately after init yields a working auth endpoint.
if bunx wrangler whoami >/dev/null 2>&1; then
  mise run d1:create
  mise run secret:put
  mise run migrate:remote
else
  echo "ℹ Skipping remote bootstrap — run \`bunx wrangler login\` (or re-run init with --headless), then \`mise run d1:create && mise run secret:put && mise run migrate:remote\`"
fi

if [ "${usage_github:-false}" = "true" ]; then
  if ! git rev-parse --verify HEAD >/dev/null 2>&1; then
    git add -A
    git commit -q -m "initial commit from cloudflare-better-auth-d1 template"
    echo "✓ initial commit"
  fi
  if git remote get-url origin >/dev/null 2>&1; then
    echo "• origin already set — skipping gh repo create"
  else
    gh repo create "{{ project_slug }}" --private --source=. --push
    echo "✓ private GitHub repo created and upstream set"
  fi
fi
'''

[tasks."worktree-init"]
description = "Spin up a fresh worktree for local dev: install deps, seed .dev.vars, reset+migrate local D1, and pull prod data via read-only export (no remote writes)"
run = '''
set -e

bunx wrangler whoami >/dev/null 2>&1 || {
  echo "✗ wrangler is not authenticated — run: bunx wrangler login" >&2
  echo "  (or export CLOUDFLARE_API_TOKEN, e.g. via: fnox exec -- mise run worktree-init)" >&2
  exit 1
}

bun install
bun install --cwd web

if [ -f .dev.vars ]; then
  echo "• .dev.vars already exists — leaving it alone"
else
  {
    echo "BETTER_AUTH_URL=http://localhost:5173"
    printf 'BETTER_AUTH_SECRET=%s\n' "$(openssl rand -base64 32)"
  } > .dev.vars
  echo "✓ created .dev.vars"
fi

# Wipe local D1 so re-running this task is idempotent (no PK conflicts on re-import).
# Destructive only against the local miniflare SQLite file — never touches remote.
rm -rf .wrangler/state/v3/d1
echo "✓ wiped local D1 state"

mise run migrate:local

# Pull prod data via read-only export. --no-schema skips DDL (migrations above
# created it). If the project adds FTS or other virtual tables, narrow this
# with `--table=<name>` flags so the local triggers — not the export's
# shadow-table INSERTs — populate the FTS index.
out=$(mktemp -t {{ project_slug }}-prod-data.XXXXXX.sql)
trap 'rm -f "$out"' EXIT

bunx wrangler d1 export {{ d1_database_name }} --remote --no-schema --output="$out"

# Apply via sqlite3 CLI rather than `wrangler d1 execute --local` because
# wrangler enforces D1's ~1MB per-statement limit even locally, and large
# row payloads (e.g. blobs, long text columns) can blow past it
# (SQLITE_TOOBIG). The miniflare SQLite file has no such cap.
command -v sqlite3 >/dev/null 2>&1 || { echo "✗ worktree-init requires the sqlite3 CLI" >&2; exit 1; }
sqlite_file=$(find .wrangler/state/v3/d1/miniflare-D1DatabaseObject -maxdepth 1 -name '*.sqlite' ! -name 'metadata.sqlite' -print -quit)
[ -n "$sqlite_file" ] || { echo "✗ could not locate local D1 SQLite file under .wrangler/state/v3/d1" >&2; exit 1; }
sqlite3 "$sqlite_file" ".read $out"

echo "✓ local D1 populated from prod data — run: mise run dev"
'''

[tasks."web:build"]
description = "Build the Vite SPA into web/dist"
dir = "web"
run = "bun run build"
sources = ["src/**/*", "index.html", "vite.config.ts", "package.json", "tsconfig.json", "tsconfig.app.json"]
outputs = ["dist/**/*"]

[tasks.dev]
description = "Vite dev server (SPA + HMR) on :5173 alongside wrangler dev (Worker) on :8787"
run = '''
# Vite serves the SPA with hot-module reload on :5173; wrangler dev runs
# the Worker on :8787. Vite's `server.proxy` forwards `/api` (extend in
# web/vite.config.ts as the worker grows new top-level routes) so the
# React app sees a single origin. Browse to http://localhost:5173 —
# BETTER_AUTH_URL in .dev.vars must match it (the `init` task seeds
# that automatically). The trap kills the background vite when wrangler
# exits (Ctrl+C, crash).
( cd web && bunx vite ) &
vite_pid=$!
trap 'kill $vite_pid 2>/dev/null; exit' EXIT INT TERM
bunx wrangler dev
'''

[tasks.typecheck]
description = "Typecheck Worker + web"
run = [
  "bunx tsc --noEmit",
  "cd web && bunx tsc --noEmit",
]

[tasks."auth:generate"]
description = "Regenerate src/db/schema.ts from better-auth config"
run = "bunx better-auth generate --config ./better-auth.config.ts --output ./src/db/schema.ts -y"

[tasks."db:generate"]
description = "Generate drizzle migration from the updated schema"
run = "bunx drizzle-kit generate"

[tasks."d1:create"]
description = "Create the remote D1 and patch database_id into wrangler.jsonc (idempotent)"
run = '''
placeholder="REPLACE_WITH_ID_FROM_wrangler_d1_create"

if ! grep -q "$placeholder" wrangler.jsonc; then
  echo "✓ wrangler.jsonc already has a database_id — skipping"
  exit 0
fi

command -v jq >/dev/null 2>&1 || { echo "✗ d1:create requires jq (https://jqlang.org)" >&2; exit 1; }

id=""
if list_json=$(bunx wrangler d1 list --json 2>/dev/null); then
  id=$(printf '%s' "$list_json" | jq -r --arg name "{{ d1_database_name }}" '.[] | select(.name == $name) | .uuid' | head -1)
fi

if [ -n "$id" ]; then
  echo "• remote D1 '{{ d1_database_name }}' already exists — reusing $id"
else
  # Answer wrangler's interactive "add binding for me?" prompt with "n" so it does not
  # append a second d1_databases entry — we patch the existing DB binding ourselves.
  create_out=$(printf 'n\n' | bunx wrangler d1 create "{{ d1_database_name }}" 2>&1) || {
    printf '%s\n' "$create_out" >&2
    exit 1
  }
  printf '%s\n' "$create_out"
  id=$(printf '%s' "$create_out" | grep -oE '[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}' | head -1)
fi

if [ -z "$id" ]; then
  echo "✗ could not determine D1 database_id from wrangler output" >&2
  exit 1
fi

tmp=$(mktemp)
sed "s|$placeholder|$id|" wrangler.jsonc > "$tmp" && mv "$tmp" wrangler.jsonc
echo "✓ wrangler.jsonc patched with database_id $id"
'''

[tasks."migrate:local"]
description = "Apply migrations to the local D1"
run = "bunx wrangler d1 migrations apply {{ d1_database_name }} --local"

[tasks."migrate:remote"]
description = "Apply migrations to the remote D1"
run = "bunx wrangler d1 migrations apply {{ d1_database_name }} --remote"

[tasks."builds:connect"]
description = "Wire Cloudflare Workers Builds to origin's GitHub repo — repo connection + main (deploy) + preview (versions upload) triggers (idempotent)"
run = '''
command -v jq >/dev/null 2>&1 || { echo "✗ builds:connect requires jq (https://jqlang.org)" >&2; exit 1; }
command -v gh >/dev/null 2>&1 || { echo "✗ builds:connect requires the gh CLI (https://cli.github.com)" >&2; exit 1; }
gh auth status >/dev/null 2>&1 || { echo "✗ gh is not authenticated — run: gh auth login" >&2; exit 1; }

if [ -n "${CLOUDFLARE_API_TOKEN:-}" ]; then
  cfcurl() { curl -sS -H "Authorization: Bearer $CLOUDFLARE_API_TOKEN" "$@"; }
elif [ -n "${CLOUDFLARE_API_KEY:-}" ] && [ -n "${CLOUDFLARE_EMAIL:-}" ]; then
  cfcurl() { curl -sS -H "X-Auth-Email: $CLOUDFLARE_EMAIL" -H "X-Auth-Key: $CLOUDFLARE_API_KEY" "$@"; }
else
  echo "✗ builds:connect needs one of:" >&2
  echo "    CLOUDFLARE_API_TOKEN           (scoped token, preferred — needs Workers Builds Configuration: Edit)" >&2
  echo "    CLOUDFLARE_API_KEY + CLOUDFLARE_EMAIL  (global key fallback)" >&2
  exit 1
fi

API=https://api.cloudflare.com/client/v4
worker="{{ worker_name }}"

origin=$(git remote get-url origin 2>/dev/null || true)
case "$origin" in
  *github.com*) ;;
  *) echo "✗ git remote 'origin' is not a GitHub URL. Run 'mise init --github' first." >&2; exit 1 ;;
esac
repo_slug=$(printf '%s' "$origin" | sed -E -e 's#^.*github\.com[/:]##' -e 's#\.git$##')

acct="${CLOUDFLARE_ACCOUNT_ID:-}"
if [ -z "$acct" ]; then
  acct=$(cfcurl "$API/accounts" | jq -r '.result[0].id // empty')
fi
[ -n "$acct" ] || { echo "✗ could not determine CF account id (set CLOUDFLARE_ACCOUNT_ID)" >&2; exit 1; }

tag=$(cfcurl "$API/accounts/$acct/workers/scripts" | jq -r --arg name "$worker" '.result[] | select(.id==$name) | .tag' | head -1)
[ -n "$tag" ] || { echo "✗ worker '$worker' not found in account $acct — run 'mise deploy' first" >&2; exit 1; }

repo_json=$(gh api "repos/$repo_slug")
gh_rid=$(printf '%s' "$repo_json" | jq -r '.id')
gh_rname=$(printf '%s' "$repo_json" | jq -r '.name')
# provider_account_* must match the repo owner (org or user), not the gh token
# identity — org-owned repos fail with 8000012 if we send the token user's id.
gh_uid=$(printf '%s' "$repo_json" | jq -r '.owner.id')
gh_uname=$(printf '%s' "$repo_json" | jq -r '.owner.login')

echo "• Connecting $repo_slug → $worker..."
conn_body=$(jq -n --arg pid "$gh_uid" --arg pname "$gh_uname" --arg rid "$gh_rid" --arg rname "$gh_rname" \
  '{provider_type:"github", provider_account_id:$pid, provider_account_name:$pname, repo_id:$rid, repo_name:$rname}')
conn_resp=$(cfcurl -X PUT -H "Content-Type: application/json" "$API/accounts/$acct/builds/repos/connections" -d "$conn_body")
conn_uuid=$(printf '%s' "$conn_resp" | jq -r '.result.repo_connection_uuid // empty')
if [ -z "$conn_uuid" ]; then
  if printf '%s' "$conn_resp" | jq -e '.errors[]? | select((.message // "") | test("authoriz"; "i"))' >/dev/null; then
    echo "✗ Cloudflare Workers & Pages GitHub App not authorized on your GH account/org." >&2
    echo "  One-time action: install https://github.com/apps/cloudflare-workers-and-pages on $(printf '%s' "$repo_slug" | cut -d/ -f1)." >&2
    exit 1
  fi
  echo "✗ repo connection failed: $conn_resp" >&2; exit 1
fi
echo "  ✓ repo connection $conn_uuid"

tok=$(cfcurl "$API/accounts/$acct/builds/tokens" | jq -r '.result[0].build_token_uuid // empty')
if [ -z "$tok" ]; then
  echo "✗ no build tokens on the account. One-time action:" >&2
  echo "  CF dashboard → Workers & Pages → any Worker → Settings → Builds → API token → create." >&2
  exit 1
fi

# List live triggers once so upsert_trigger can diff against declared intent.
existing=$(cfcurl "$API/accounts/$acct/builds/workers/$tag/triggers")
if ! printf '%s' "$existing" | jq -e '.success' >/dev/null; then
  echo "✗ could not list existing triggers: $existing" >&2
  exit 1
fi

upsert_trigger() {
  local name="$1" build_cmd="$2" deploy_cmd="$3" includes="$4" excludes="$5"
  local match existing_uuid body resp got_b got_d got_inc got_exc want_inc want_exc

  match=$(printf '%s' "$existing" | jq --arg name "$name" \
    '.result[] | select(.deleted_on==null and .trigger_name==$name) | {uuid:.trigger_uuid, build_command, deploy_command, branch_includes, branch_excludes}')
  existing_uuid=$(printf '%s' "$match" | jq -r '.uuid // empty')

  if [ -z "$existing_uuid" ]; then
    body=$(jq -n --arg tag "$tag" --arg conn "$conn_uuid" --arg tok "$tok" \
                 --arg name "$name" --arg b "$build_cmd" --arg d "$deploy_cmd" \
                 --argjson inc "$includes" --argjson exc "$excludes" \
      '{external_script_id:$tag, repo_connection_uuid:$conn, build_token_uuid:$tok, trigger_name:$name, build_command:$b, deploy_command:$d, root_directory:"/", branch_includes:$inc, branch_excludes:$exc}')
    resp=$(cfcurl -X POST -H "Content-Type: application/json" "$API/accounts/$acct/builds/triggers" -d "$body")
    if printf '%s' "$resp" | jq -e '.success' >/dev/null; then
      echo "  ✓ $name trigger created"
    elif printf '%s' "$resp" | jq -e '.errors[]? | select(.code==12030)' >/dev/null; then
      # 12030 = per-worker trigger count limit hit. Most likely cause: triggers
      # created through the dashboard under different names (e.g. "Deploy default
      # branch"). List them so the user can clean up and re-run.
      echo "  ⚠ $name trigger not created — per-worker trigger limit reached." >&2
      echo "    Existing triggers for this worker (delete the stale ones and re-run):" >&2
      printf '%s' "$existing" | jq -r '.result[] | select(.deleted_on==null) | "      • " + .trigger_name + "  [" + .trigger_uuid + "]  build=" + .build_command' >&2
      exit 1
    else
      echo "✗ $name trigger creation failed: $resp" >&2
      exit 1
    fi
    return
  fi

  want_inc=$(printf '%s' "$includes" | jq -c '.')
  want_exc=$(printf '%s' "$excludes" | jq -c '.')
  got_b=$(printf '%s' "$match" | jq -r '.build_command')
  got_d=$(printf '%s' "$match" | jq -r '.deploy_command')
  got_inc=$(printf '%s' "$match" | jq -c '.branch_includes')
  got_exc=$(printf '%s' "$match" | jq -c '.branch_excludes')

  if [ "$got_b" = "$build_cmd" ] && [ "$got_d" = "$deploy_cmd" ] && [ "$got_inc" = "$want_inc" ] && [ "$got_exc" = "$want_exc" ]; then
    echo "  ✓ $name trigger already matches — skipping"
    return
  fi

  body=$(jq -n --arg b "$build_cmd" --arg d "$deploy_cmd" \
               --argjson inc "$includes" --argjson exc "$excludes" \
    '{build_command:$b, deploy_command:$d, branch_includes:$inc, branch_excludes:$exc}')
  resp=$(cfcurl -X PATCH -H "Content-Type: application/json" "$API/accounts/$acct/builds/triggers/$existing_uuid" -d "$body")
  if printf '%s' "$resp" | jq -e '.success' >/dev/null; then
    echo "  ✓ $name trigger updated"
  else
    echo "✗ $name trigger update failed: $resp" >&2
    exit 1
  fi
}

# `branch_includes: ["*"]` is only accepted alongside a non-empty `branch_excludes`.
# That's the API shape for "all non-production branches" — it's how the dashboard
# checkbox is implemented under the hood, not a separate is_production flag.
upsert_trigger "main"    "bun run ci:build"         "npx wrangler deploy"          '["main"]' '[]'
upsert_trigger "preview" "bun run ci:build:preview" "npx wrangler versions upload" '["*"]'    '["main"]'

echo "✓ Workers Builds ready — push to 'main' deploys; push to any other branch produces a preview URL commented on the PR."
'''

[tasks."ci:local"]
description = "Local mirror of `bun run ci:build`: install deps, build SPA, apply local D1 migrations (no deploy)"
run = [
  "bun install",
  "bun install --cwd web",
  "cd web && bun run build",
  "bun run db:migrate:local",
]

[tasks."secret:put"]
description = "Ensure BETTER_AUTH_SECRET is set on the remote Worker (idempotent — skips if already present)"
run = '''
command -v jq >/dev/null 2>&1 || { echo "✗ secret:put requires jq (https://jqlang.org)" >&2; exit 1; }

if out=$(bunx wrangler secret list 2>/dev/null) && printf '%s' "$out" | jq -e 'any(.name == "BETTER_AUTH_SECRET")' >/dev/null 2>&1; then
  echo "✓ BETTER_AUTH_SECRET already set on {{ worker_name }} — skipping"
  exit 0
fi

# wrangler secret put auto-creates an empty Worker stub if {{ worker_name }} does not exist yet,
# so this works both pre- and post-first-deploy.
openssl rand -base64 32 | bunx wrangler secret put BETTER_AUTH_SECRET
'''

[tasks.deploy]
description = "Build the SPA and deploy the Worker (auto-patches BETTER_AUTH_URL on first deploy)"
depends = ["web:build"]
run = '''
if grep -q REPLACE_WITH_ID_FROM_wrangler_d1_create wrangler.jsonc; then
  echo "✗ wrangler.jsonc still has the D1 id placeholder — run: mise run d1:create" >&2
  exit 1
fi

placeholder='"BETTER_AUTH_URL": "http://localhost:8787"'

deploy_out=$(bunx wrangler deploy 2>&1) || {
  printf '%s\n' "$deploy_out" >&2
  exit 1
}
printf '%s\n' "$deploy_out"

if ! grep -qF "$placeholder" wrangler.jsonc; then
  exit 0
fi

# Extract the canonical *.workers.dev URL wrangler prints under "Deployed <worker> triggers".
# The worker-name-scoped regex skips Cloudflare preview URLs (https://{version}-{worker}...).
url=$(printf '%s' "$deploy_out" | grep -oE "https://{{ worker_name }}\.[a-z0-9-]+\.workers\.dev" | head -1)

if [ -z "$url" ]; then
  echo "⚠ wrangler deploy succeeded but no *.workers.dev URL was found in its output." >&2
  echo "  If you are using a custom domain or have disabled workers.dev, edit" >&2
  echo "  vars.BETTER_AUTH_URL in wrangler.jsonc and re-run 'mise run deploy'." >&2
  exit 0
fi

replacement="\"BETTER_AUTH_URL\": \"$url\""
tmp=$(mktemp)
sed "s|$placeholder|$replacement|" wrangler.jsonc > "$tmp" && mv "$tmp" wrangler.jsonc
echo "✓ wrangler.jsonc patched: BETTER_AUTH_URL → $url"
echo "↻ redeploying so the Worker env picks up the new BETTER_AUTH_URL..."
bunx wrangler deploy
'''

[tasks.teardown]
description = "Delete the remote Worker and D1 database (irreversible)"
run = [
  "bunx wrangler delete --name {{ worker_name }}",
  "bunx wrangler d1 delete {{ d1_database_name }} -y",
]
