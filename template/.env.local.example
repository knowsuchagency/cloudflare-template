# Copy to .env.local (gitignored) if you can't use `wrangler login`
# (e.g. headless Linux box without xdg-open).
#
# Option A — scoped API token (preferred): create at
# https://dash.cloudflare.com/profile/api-tokens with Workers Scripts:Edit,
# Workers R2 Storage:Edit, D1:Edit (plus any others you need).
CLOUDFLARE_API_TOKEN=

# Option B — global API key fallback. Leave CLOUDFLARE_API_TOKEN empty above.
# CLOUDFLARE_API_KEY=
# CLOUDFLARE_EMAIL=
